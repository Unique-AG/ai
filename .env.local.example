# Claude Agent SDK Integration — Environment Variables
#
# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored and will NEVER be committed.
#
# Usage (integration tests + demo):
#   set -a && source .env.local && set +a
#   cd unique_toolkit && poetry run pytest tests/agentic/claude_agent/test_integration.py -v -s -k "L1"

# ──────────────────────────────────────────────────────────────────────────────
# Required for ALL tests and the streaming demo
# ──────────────────────────────────────────────────────────────────────────────

# Your Anthropic API key. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ──────────────────────────────────────────────────────────────────────────────
# Required for Level-2 integration tests (real Unique platform, QA environment)
# ──────────────────────────────────────────────────────────────────────────────

# Unique platform API credentials — obtain from your QA environment settings
UNIQUE_APP_KEY=your-unique-app-key
UNIQUE_APP_ID=your-unique-app-id
UNIQUE_API_BASE_URL=https://next.qa.unique.app/api

# User identity used by ContentService / MCP calls in tests
UNIQUE_AUTH_COMPANY_ID=your-company-id
UNIQUE_AUTH_USER_ID=your-user-id

# ──────────────────────────────────────────────────────────────────────────────
# Required for workspace e2e + multi-turn e2e tests
# ──────────────────────────────────────────────────────────────────────────────

# Chat ID used by workspace_e2e and multiturn_e2e tests.
# Find it in the URL when you open a chat: https://next.qa.unique.app/chat/<chat_id>
UNIQUE_TEST_CHAT_ID=chat_your_chat_id_here

# ──────────────────────────────────────────────────────────────────────────────
# Optional — KB search test context
# ──────────────────────────────────────────────────────────────────────────────

# Scope ID of the knowledge base folder to search in L2 KB tests.
# Find it in the QA KB URL: https://next.qa.unique.app/knowledge-upload/<scope_id>
UNIQUE_TEST_SCOPE_ID=scope_your_scope_id_here

# Scope ID for the skills KB folder (skills download test in test_workspace_e2e.py).
# Find it the same way as UNIQUE_TEST_SCOPE_ID.
UNIQUE_TEST_SKILLS_SCOPE_ID=scope_your_skills_scope_id_here
