{{ begin_marker }}
{% for group in groups %}
{% if not loop.first %}

{% endif %}
{{ group.helm_key }}:
{% if group.kind == "urlSafety" %}
  enabled: {{ group.enabled_literal }}
{% else %}
  enabled: false
{% endif %}
{% for section in group.sections %}
  {{ section.name }}:
{% if not section.has_values %}
    {}
{% endif %}
{% for row in section.rows %}
{% if row.literal is not none %}
    {{ row.helm_name }}: {{ row.literal }}
{% elif row.container_items %}
    # {{ row.helm_name }} ({{ container_note }}):
{% for item in row.container_items %}
    #   - {{ item }}
{% endfor %}
{% else %}
    # {{ row.helm_name }}: {{ row.placeholder }}
{% endif %}
{% endfor %}
{% endfor %}
{% endfor %}
{{ end_marker }}
