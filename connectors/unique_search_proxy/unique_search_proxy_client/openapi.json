{
  "openapi": "3.1.0",
  "info": {
    "title": "Unique Search Proxy",
    "description": "Unified web egress proxy for search engines and crawlers. Use **Try it out** on `/v1/search` and `/v1/crawl` \u2014 pick an example from the request-body dropdown (snippets-only Google search, crawl with HTML markdown, etc.). Requires provider env vars (e.g. `GOOGLE_SEARCH_API_KEY`, `GOOGLE_SEARCH_ENGINE_ID`) for live calls.",
    "version": "0.2.0"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Health",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Health Health Get"
                }
              }
            }
          }
        }
      }
    },
    "/ready": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Ready",
        "operationId": "ready_ready_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Ready Ready Get"
                }
              }
            }
          }
        }
      }
    },
    "/v1/configuration/providers": {
      "get": {
        "tags": [
          "configuration"
        ],
        "summary": "List registered search engines and crawlers",
        "operationId": "list_providers_v1_configuration_providers_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProvidersListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/search": {
      "post": {
        "tags": [
          "search"
        ],
        "summary": "Run a search engine with a typed call payload",
        "operationId": "search_v1_search_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "anyOf": [
                  {
                    "$ref": "#/components/schemas/GoogleRequest"
                  },
                  {
                    "$ref": "#/components/schemas/BraveRequest"
                  },
                  {
                    "$ref": "#/components/schemas/PerplexityRequest"
                  }
                ],
                "title": "Body"
              },
              "examples": {
                "google_search": {
                  "summary": "Google search",
                  "description": "Flat search request; requires GOOGLE_SEARCH_API_KEY and GOOGLE_SEARCH_ENGINE_ID in .env.",
                  "value": {
                    "engine": "google",
                    "query": "unique ag",
                    "fetchSize": 10,
                    "safe": "active",
                    "timeout": 30
                  }
                },
                "google_search_with_gl": {
                  "summary": "Google search (with gl and dateRestrict)",
                  "description": "Full execution payload including optional provider parameters.",
                  "value": {
                    "engine": "google",
                    "query": "unique ag",
                    "fetchSize": 10,
                    "gl": "ch",
                    "dateRestrict": "d7",
                    "safe": "active",
                    "timeout": 30
                  }
                },
                "perplexity_search": {
                  "summary": "Perplexity search",
                  "description": "Flat search request; requires PERPLEXITY_SEARCH_API_KEY in .env.",
                  "value": {
                    "engine": "perplexity",
                    "query": "unique ag",
                    "fetchSize": 10,
                    "timeout": 30
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/crawl": {
      "post": {
        "tags": [
          "crawl"
        ],
        "summary": "Crawl URLs with a configured crawler",
        "operationId": "crawl_v1_crawl_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BasicCrawlerRequest"
              },
              "examples": {
                "basic_raw": {
                  "summary": "Basic crawl (raw body only)",
                  "description": "Returns raw response text and contentType; content stays null.",
                  "value": {
                    "urls": [
                      "https://example.com"
                    ],
                    "crawler": "BasicCrawler",
                    "contentTypes": {
                      "html": false,
                      "xhtml": false,
                      "plainText": false,
                      "markdown": false,
                      "pdf": false
                    },
                    "timeout": 30
                  }
                },
                "basic_html_markdown": {
                  "summary": "Basic crawl (HTML to markdown)",
                  "description": "Processes allowed content types into the content field.",
                  "value": {
                    "urls": [
                      "https://example.com"
                    ],
                    "crawler": "BasicCrawler",
                    "contentTypes": {
                      "html": true,
                      "xhtml": true
                    },
                    "timeout": 30
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CrawlResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BasicCrawlerRequest": {
        "properties": {
          "urls": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "minItems": 1,
            "title": "Urls",
            "description": "URLs to crawl"
          },
          "crawler": {
            "type": "string",
            "const": "BasicCrawler",
            "title": "Crawler",
            "default": "BasicCrawler"
          },
          "timeout": {
            "type": "integer",
            "title": "Timeout",
            "description": "Request timeout in seconds",
            "default": 30
          },
          "contentTypes": {
            "$ref": "#/components/schemas/ContentTypeToggles",
            "title": "Content types",
            "description": "Enable built-in processing per media type. Unchecked types return raw body only.",
            "default": {
              "html": true,
              "xhtml": true,
              "plainText": true,
              "markdown": true,
              "pdf": false
            }
          },
          "maxConcurrentRequests": {
            "type": "integer",
            "title": "Maximum concurrent HTTP fetches",
            "description": "Maximum concurrent HTTP fetches",
            "default": 10
          }
        },
        "type": "object",
        "required": [
          "urls"
        ],
        "title": "Basic Proxy Crawler "
      },
      "BraveRequest": {
        "properties": {
          "query": {
            "type": "string",
            "minLength": 1,
            "title": "Query",
            "description": "Search query string"
          },
          "engine": {
            "type": "string",
            "const": "brave",
            "title": "Search engine",
            "description": "Provider discriminator; must be `brave` for this config.",
            "default": "brave"
          },
          "fetchSize": {
            "type": "integer",
            "title": "Fetch Size",
            "description": "Default result count merged into each search request",
            "default": 10
          },
          "timeout": {
            "type": "integer",
            "title": "Timeout",
            "description": "Request timeout in seconds",
            "default": 30
          },
          "extraSnippets": {
            "type": "boolean",
            "title": "Extra snippets",
            "description": "Request up to five additional alternative excerpts per result (Brave `extra_snippets`).",
            "default": true
          },
          "spellcheck": {
            "type": "boolean",
            "title": "Spellcheck",
            "description": "Whether Brave spell-checks the query and uses the corrected form.",
            "default": false
          },
          "textDecorations": {
            "type": "boolean",
            "title": "Text decorations",
            "description": "Whether result snippets include decoration markers (e.g. highlighting).",
            "default": true
          },
          "operators": {
            "type": "boolean",
            "title": "Search operators",
            "description": "Whether Brave applies search operators in the query.",
            "default": true
          },
          "uiLang": {
            "type": "string",
            "title": "UI language",
            "description": "User interface language for response strings (Brave `ui_lang`), e.g. `en-US`. Distinct from `search_lang`.",
            "default": "en-US"
          },
          "units": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "metric",
                  "imperial"
                ]
              },
              {
                "type": "null"
              }
            ],
            "title": "Measurement units",
            "description": "Measurement units for location-rich results: `metric` or `imperial`."
          },
          "summary": {
            "type": "boolean",
            "title": "Summary",
            "description": "Enable summary key generation in web search results (Brave summarizer).",
            "default": true
          },
          "includeFetchMetadata": {
            "type": "boolean",
            "title": "Include fetch metadata",
            "description": "Include fetch metadata in the Brave response.",
            "default": false
          },
          "goggles": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              }
            ],
            "title": "Goggles",
            "description": "Custom re-ranking Goggle URL(s) or definition(s). Up to three Goggles per request."
          },
          "country": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Country",
            "description": "Two-letter ISO 3166-1 alpha-2 country code for result origin (Brave `country`). Set `value` for a fixed default; set `expose` so the LLM may override per query."
          },
          "freshness": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Freshness",
            "description": "Recency filter: `pd`, `pw`, `pm`, `py`, or `YYYY-MM-DDtoYYYY-MM-DD`. `value` + `expose` behave like `country`."
          },
          "searchLang": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Search language",
            "description": "Language code for result documents (Brave `search_lang`). `value` + `expose` behave like `country`."
          },
          "safesearch": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "off",
                  "moderate",
                  "strict"
                ]
              },
              {
                "type": "null"
              }
            ],
            "title": "Safe search",
            "description": "Adult content filter: `off`, `moderate` (API default), or `strict`. Usually set via admin `value`; enable `expose` only if the LLM may tune per query."
          },
          "resultFilter": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Result filter",
            "description": "Result types to include, e.g. `web`, `news`, `videos`. Omit (`null`) for all subscribed types. `value` + `expose` behave like `country`."
          }
        },
        "type": "object",
        "required": [
          "query"
        ],
        "title": "Brave Request"
      },
      "ContentTypeToggles": {
        "properties": {
          "html": {
            "type": "boolean",
            "title": "HTML",
            "description": "text/html",
            "default": true
          },
          "xhtml": {
            "type": "boolean",
            "title": "XHTML",
            "description": "application/xhtml+xml",
            "default": true
          },
          "plainText": {
            "type": "boolean",
            "title": "Plain text",
            "description": "text/plain",
            "default": true
          },
          "markdown": {
            "type": "boolean",
            "title": "Markdown",
            "description": "text/markdown",
            "default": true
          },
          "pdf": {
            "type": "boolean",
            "title": "PDF",
            "description": "application/pdf",
            "default": false
          }
        },
        "type": "object",
        "title": "Content Types",
        "description": "Per-type activation flags for basic-crawler content processing."
      },
      "CrawlResponse": {
        "properties": {
          "crawler": {
            "type": "string",
            "title": "Crawler"
          },
          "results": {
            "items": {
              "$ref": "#/components/schemas/CrawlUrlResult"
            },
            "type": "array",
            "title": "Results"
          }
        },
        "type": "object",
        "required": [
          "crawler",
          "results"
        ],
        "title": "Crawl Response"
      },
      "CrawlUrlResult": {
        "properties": {
          "url": {
            "type": "string",
            "title": "Url"
          },
          "content": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Content",
            "description": "Markdown extracted from HTML responses; null when unprocessed"
          },
          "contentType": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Content Type",
            "description": "Response Content-Type (media type only, parameters stripped)"
          },
          "error": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/PerUrlError"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error"
          },
          "raw": {
            "anyOf": [
              {},
              {
                "type": "null"
              }
            ],
            "title": "Raw",
            "description": "Unmodified response body text, or null when no body was received"
          }
        },
        "type": "object",
        "required": [
          "url"
        ],
        "title": "Crawl Url Result"
      },
      "GoogleRequest": {
        "properties": {
          "query": {
            "type": "string",
            "minLength": 1,
            "title": "Query",
            "description": "Search query string"
          },
          "engine": {
            "type": "string",
            "const": "google",
            "title": "Search engine",
            "description": "Provider discriminator; must be `google` for this config.",
            "default": "google"
          },
          "fetchSize": {
            "type": "integer",
            "title": "Fetch Size",
            "description": "Default result count merged into each search request",
            "default": 10
          },
          "timeout": {
            "type": "integer",
            "title": "Timeout",
            "description": "Request timeout in seconds",
            "default": 30
          },
          "searchEngineId": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Search engine ID (cx)",
            "description": "Google Programmable Search Engine ID (`cx`). Resolved from deployment env at runtime when not set. Not sent as a query parameter."
          },
          "safe": {
            "type": "string",
            "enum": [
              "active",
              "off"
            ],
            "title": "Safe search",
            "description": "SafeSearch level for every search: `active` (default) or `off`. Applied on all requests unless the call body overrides it.",
            "default": "active"
          },
          "gl": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Geolocation (gl)",
            "description": "Two-letter ISO 3166-1 alpha-2 country code (Google `gl`). Set `value` for a fixed default; set `expose` so the LLM may override per query."
          },
          "hl": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Interface language (hl)",
            "description": "Language for snippets/UI (Google `hl`). `value` + `expose` behave like `gl`."
          },
          "lr": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Language restrict (lr)",
            "description": "Document language restrict (Google `lr`), e.g. `lang_en`. `value` + `expose` behave like `gl`."
          },
          "dateRestrict": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Date restrict",
            "description": "Google `dateRestrict` recency filter (`d7`, `m1`, \u2026). `value` + `expose` behave like `gl`."
          },
          "exactTerms": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Exact terms",
            "description": "Phrase every hit must contain (Google `exactTerms`). `value` + `expose` behave like `gl`."
          },
          "excludeTerms": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Exclude terms",
            "description": "Phrase that must not appear (Google `excludeTerms`). `value` + `expose` behave like `gl`."
          },
          "fileType": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "File type",
            "description": "File extension filter (Google `fileType`), e.g. `pdf`. `value` + `expose` behave like `gl`."
          },
          "siteSearch": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Site search",
            "description": "Site or domain (Google `siteSearch`). Pair with `siteSearchFilter`. `value` + `expose` behave like `gl`."
          },
          "siteSearchFilter": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "e",
                  "i"
                ]
              },
              {
                "type": "null"
              }
            ],
            "title": "Site search filter",
            "description": "With `siteSearch`: `i` = include only that site, `e` = exclude. `value` + `expose` behave like `gl`."
          },
          "sort": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Sort",
            "description": "Sort expression (Google `sort`), e.g. `date`. `value` + `expose` behave like `gl`."
          }
        },
        "type": "object",
        "required": [
          "query"
        ],
        "title": "Google Request"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "PerUrlError": {
        "properties": {
          "code": {
            "type": "string",
            "title": "Code"
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "title": "Per Url Error"
      },
      "PerplexityRequest": {
        "properties": {
          "query": {
            "type": "string",
            "minLength": 1,
            "title": "Query",
            "description": "Search query string"
          },
          "engine": {
            "type": "string",
            "const": "perplexity",
            "title": "Search engine",
            "description": "Provider discriminator; must be `perplexity` for this config.",
            "default": "perplexity"
          },
          "fetchSize": {
            "type": "integer",
            "title": "Fetch Size",
            "description": "Default result count merged into each search request",
            "default": 10
          },
          "timeout": {
            "type": "integer",
            "title": "Timeout",
            "description": "Request timeout in seconds",
            "default": 30
          },
          "maxTokens": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max tokens",
            "description": "Maximum total webpage content tokens across all results (Perplexity `max_tokens`). Omitted when unset. Omit `search_context_size` when using this or `max_tokens_per_page`."
          },
          "maxTokensPerPage": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max tokens per page",
            "description": "Maximum webpage content tokens extracted from each result page (Perplexity `max_tokens_per_page`). Omitted when unset. Omit `search_context_size` when using this or `max_tokens`."
          },
          "country": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Country",
            "description": "ISO 3166-1 alpha-2 country code (Perplexity `country`, two letters). Set `value` for a fixed default; set `expose` so the LLM may override per query."
          },
          "searchContextSize": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high"
                ]
              },
              {
                "type": "null"
              }
            ],
            "title": "Search context size",
            "description": "Controls how much content is extracted from result pages: `low`, `medium`, or `high` (API default). Omit when using `max_tokens` or `max_tokens_per_page`. `value` + `expose` behave like `country`."
          },
          "searchLanguageFilter": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Search language filter",
            "description": "ISO 639-1 language codes (two characters each, up to 20). `value` + `expose` behave like `country`."
          },
          "searchDomainFilter": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Search domain filter",
            "description": "Limit results to specific domains (up to 20). `value` + `expose` behave like `country`."
          },
          "searchRecencyFilter": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "hour",
                  "day",
                  "week",
                  "month",
                  "year"
                ]
              },
              {
                "type": "null"
              }
            ],
            "title": "Search recency filter",
            "description": "Filter by publication recency: `hour`, `day`, `week`, `month`, or `year`. `value` + `expose` behave like `country`."
          },
          "lastUpdatedAfterFilter": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last updated after",
            "description": "Return results updated after this date (Perplexity `last_updated_after_filter`, input format `MM/DD/YYYY`). `value` + `expose` behave like `country`."
          },
          "lastUpdatedBeforeFilter": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last updated before",
            "description": "Return results updated before this date (Perplexity `last_updated_before_filter`, input format `MM/DD/YYYY`). `value` + `expose` behave like `country`."
          },
          "searchAfterDateFilter": {
            "anyOf": [
              {
                "type": "string"
              },
              {
