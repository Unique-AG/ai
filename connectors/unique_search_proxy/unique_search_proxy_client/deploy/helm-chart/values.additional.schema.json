{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "properties": {
    "googleSearch": {
      "type": "object",
      "additionalProperties": false,
      "description": "Google Search configuration. Generated from _GoogleCredentials (GOOGLE_SEARCH_* env vars).",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "connection": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "apiKey": {
              "description": "Maps to env var GOOGLE_SEARCH_API_KEY.",
              "$ref": "#/$defs/valueSourceSensitive"
            },
            "apiEndpoint": {
              "description": "Maps to env var GOOGLE_SEARCH_API_ENDPOINT.",
              "type": "string",
              "format": "uri"
            },
            "engineId": {
              "description": "Maps to env var GOOGLE_SEARCH_ENGINE_ID.",
              "$ref": "#/$defs/valueSourceString"
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "enabled": {
                "const": true
              }
            },
            "required": [
              "enabled"
            ]
          },
          "then": {
            "required": [
              "connection"
            ],
            "properties": {
              "connection": {
                "required": [
                  "apiKey",
                  "engineId"
                ]
              }
            }
          }
        }
      ]
    },
