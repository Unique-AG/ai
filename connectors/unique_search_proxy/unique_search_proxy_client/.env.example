# Unique Search Proxy — example environment file
# Copy to .env in this directory (or set vars in your shell / deployment):
#   cp .example.env .env
#
# Loaded via pydantic-settings (see unique_search_proxy/web/settings/base.py).
# Prefixes: HTTP_CLIENT_, PROMETHEUS_; Google vars have no prefix.

# ── Google Custom Search (required for POST /v1/search with engine=google) ───
# Create API key + Programmable Search Engine (cx) in Google Cloud Console.
# Use real values in deployment. NOT_PROVIDED (or empty) means the provider is unavailable.
GOOGLE_SEARCH_API_KEY=NOT_PROVIDED
GOOGLE_SEARCH_ENGINE_ID=NOT_PROVIDED
# Default when unset: https://www.googleapis.com/customsearch/v1
GOOGLE_SEARCH_API_ENDPOINT=https://www.googleapis.com/customsearch/v1

# ── Brave Web Search (required for POST /v1/search with engine=brave) ────────
# Subscription token from https://api-dashboard.search.brave.com/
BRAVE_SEARCH_API_KEY=NOT_PROVIDED
# Default when unset: https://api.search.brave.com/res/v1/web/search
BRAVE_SEARCH_API_ENDPOINT=https://api.search.brave.com/res/v1/web/search

# ── Perplexity Search (required for POST /v1/search with engine=perplexity) ──
# API key from https://www.perplexity.ai/settings/api
PERPLEXITY_SEARCH_API_KEY=NOT_PROVIDED
# Default when unset: https://api.perplexity.ai/search
PERPLEXITY_SEARCH_API_ENDPOINT=https://api.perplexity.ai/search

# ── Tavily (crawl extract + search; required for crawler=Tavily) ─────────────
TAVILY_API_KEY=NOT_PROVIDED
# Default when unset: https://api.tavily.com (/extract, /search derived in code)
TAVILY_API_ENDPOINT=https://api.tavily.com

# ── Jina (reader + search; required for crawler=Jina) ────────────────────────
JINA_API_KEY=NOT_PROVIDED
# global (default): read https://r.jina.ai/, search https://s.jina.ai/
# eu-beta: read https://eu-r-beta.jina.ai/, search https://eu-s-beta.jina.ai/
JINA_DEPLOYMENT=global

# ── Firecrawl (batch scrape + search; required for crawler=Firecrawl) ────────
FIRECRAWL_API_KEY=NOT_PROVIDED
# Base URL (default https://api.firecrawl.dev); versioned paths are derived in code
FIRECRAWL_API_ENDPOINT=https://api.firecrawl.dev
FIRECRAWL_API_VERSION=v2

# ── Outbound HTTP client (search + crawl egress) ─────────────────────────────
# Prefix: HTTP_CLIENT_
HTTP_CLIENT_PROXY_AUTH_MODE=none
# none | username_password | ssl_tls
HTTP_CLIENT_PROXY_PROTOCOL=http
# http | https
# HTTP_CLIENT_PROXY_HOST=
# HTTP_CLIENT_PROXY_PORT=
# HTTP_CLIENT_PROXY_USERNAME=
# HTTP_CLIENT_PROXY_PASSWORD=
# HTTP_CLIENT_PROXY_SSL_CA_BUNDLE_PATH=
# HTTP_CLIENT_PROXY_SSL_CERT_PATH=
# HTTP_CLIENT_PROXY_SSL_KEY_PATH=
# JSON object, e.g. {"Proxy-Authorization": "..."}
# HTTP_CLIENT_PROXY_HEADERS={}

HTTP_CLIENT_POOL_TIMEOUT_SECONDS=30
HTTP_CLIENT_MAX_CONNECTIONS=100
HTTP_CLIENT_MAX_KEEPALIVE_CONNECTIONS=20

# ── Prometheus metrics (GET /metrics) ────────────────────────────────────────
# Prefix: PROMETHEUS_
PROMETHEUS_ENABLED=true

# ── Container / production entrypoint (deploy/entrypoint.sh) ─────────────────
# Not read by pydantic-settings; used when starting uvicorn via entrypoint.sh.
# HOST=0.0.0.0
# PORT=8080
# WORKERS=4
# TIMEOUT=120
LOG_LEVEL=info
#
# When WORKERS > 1, entrypoint sets multiprocess metrics dir:
# PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus

# ── Local development (optional) ───────────────────────────────────────────────
# uvicorn unique_search_proxy_client.web.app:app --reload --port 2349
