# =============================================================================
# Search Proxy - Experimental Image
# =============================================================================
FROM python:3.12-slim-bookworm@sha256:31c0807da611e2e377a2e9b566ad4eb038ac5a5838cbbbe6f2262259b5dc77a0

# Default matches .github/actions/setup-uv (local builds); CI passes --build-arg from setup-uv output.
ARG UV_VERSION=0.11.2

ENV PYTHONFAULTHANDLER=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONHASHSEED=random \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=off \
    PIP_DISABLE_PIP_VERSION_CHECK=on \
    PIP_DEFAULT_TIMEOUT=100 \
    UV_NO_PROGRESS=1

# Create user and install uv
RUN useradd -m appuser && \
    pip install --no-cache-dir "uv==${UV_VERSION}"

# Copy only requirements to cache them in docker layer
WORKDIR /app

ENV VIRTUAL_ENV=/app/.venv \
    PATH="/app/.venv/bin:$PATH"

COPY requirements.txt pyproject.toml ./

# Install the exact hash-pinned versions from uv.lock.
# requirements.txt is generated by `uv export --locked` in CI, so every package
# carries the sha256 hash recorded in uv.lock. --require-hashes makes pip verify
# each download against that hash — any mismatch (tampered package, wrong version,
# network substitution) causes an immediate build failure.
RUN uv venv && uv pip install --require-hashes -r requirements.txt

# Copy application code
COPY web/ ./

# Set ownership and permissions
RUN chown -R appuser:appuser /app && \
    chmod +x entrypoint.sh

USER appuser

# Expose port
EXPOSE 8080

# Entrypoint script handles startup
ENTRYPOINT ["./entrypoint.sh"]
