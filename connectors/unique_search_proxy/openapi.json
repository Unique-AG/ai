    "/v1/search": {
      "post": {
        "tags": [
          "search"
        ],
        "summary": "Run a search engine with a typed call payload",
        "operationId": "search_v1_search_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GoogleConfigRequest"
              },
              "examples": {
                "google_search": {
                  "summary": "Google search",
                  "description": "Flat search request; requires GOOGLE_SEARCH_API_KEY and GOOGLE_SEARCH_ENGINE_ID in .env.",
                  "value": {
                    "engine": "google",
                    "query": "unique ag",
                    "fetchSize": 10,
                    "safe": "active",
                    "timeout": 30
                  }
                },
                "google_search_with_gl": {
                  "summary": "Google search (with gl and dateRestrict)",
                  "description": "Full execution payload including optional provider parameters.",
                  "value": {
                    "engine": "google",
                    "query": "unique ag",
                    "fetchSize": 10,
                    "gl": "ch",
                    "dateRestrict": "d7",
                    "safe": "active",
                    "timeout": 30
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/crawl": {
      "post": {
        "tags": [
          "crawl"
        ],
        "summary": "Crawl URLs with a configured crawler",
        "operationId": "crawl_v1_crawl_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CrawlRequest"
              },
              "examples": {
                "basic_raw": {
                  "summary": "Basic crawl (raw body only)",
                  "description": "Returns raw response text and contentType; content stays null.",
                  "value": {
                    "urls": [
                      "https://example.com"
                    ],
                    "config": {
                      "crawler": "basic"
                    },
                    "parallel": true,
                    "timeout": 30
                  }
                },
                "basic_html_markdown": {
                  "summary": "Basic crawl (HTML to markdown)",
                  "description": "Processes allowed content types into the content field.",
                  "value": {
                    "urls": [
                      "https://example.com"
                    ],
                    "config": {
                      "crawler": "basic",
                      "contentTypeHandlers": {
                        "text/html": "allow",
                        "application/xhtml+xml": "allow"
                      }
                    },
                    "parallel": true,
                    "timeout": 30
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CrawlResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BasicCrawlerConfig": {
        "properties": {
          "crawler": {
            "type": "string",
            "const": "basic",
            "title": "Crawler",
            "default": "basic"
          },
          "contentTypeHandlers": {
            "additionalProperties": {
              "$ref": "#/components/schemas/ContentTypeHandlerPolicy"
            },
            "type": "object",
            "title": "Contenttypehandlers",
            "description": "Per media-type policy using exact Content-Type values (no parameters). allow: run the built-in processor into ``content``; forbid: return ``raw`` only. Types not listed are not processed.",
            "examples": [
              {
                "application/pdf": "forbid",
                "application/xhtml+xml": "allow",
                "text/html": "allow"
              }
            ]
          },
          "maxConcurrentRequests": {
            "type": "integer",
            "maximum": 50.0,
            "minimum": 1.0,
            "title": "Maxconcurrentrequests",
            "description": "Maximum concurrent HTTP fetches",
            "default": 10
          },
          "exposedFields": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Exposedfields",
            "description": "Call-schema fields exposed to LLM-driven callers (urls always exposed)"
          }
        },
        "type": "object",
        "title": "BasicCrawlerConfig",
        "description": "Deployment config for the HTTP basic crawler."
      },
      "ContentTypeHandlerPolicy": {
        "type": "string",
        "enum": [
          "allow",
          "forbid"
        ],
        "title": "ContentTypeHandlerPolicy",
        "description": "Whether the basic crawler may run the built-in processor for a media type."
      },
      "CrawlRequest": {
        "properties": {
          "urls": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "minItems": 1,
            "title": "Urls",
            "description": "URLs to crawl"
          },
          "config": {
            "$ref": "#/components/schemas/BasicCrawlerConfig"
          },
          "acceptedContentTypes": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Acceptedcontenttypes",
            "description": "Optional hint for callers (e.g. text/html). The proxy does not filter on this; consumers decide how to handle each result's contentType."
          },
          "parallel": {
            "type": "boolean",
            "title": "Parallel",
            "description": "Whether to crawl URLs concurrently",
            "default": true
          },
          "timeout": {
            "type": "integer",
            "maximum": 600.0,
            "minimum": 1.0,
            "title": "Timeout",
            "description": "Per-request timeout in seconds",
            "default": 30
          }
        },
        "type": "object",
        "required": [
          "urls",
          "config"
        ],
        "title": "CrawlRequest"
      },
      "CrawlResponse": {
        "properties": {
          "crawler": {
            "type": "string",
            "title": "Crawler"
          },
          "results": {
            "items": {
              "$ref": "#/components/schemas/CrawlUrlResult"
            },
            "type": "array",
            "title": "Results"
          }
        },
        "type": "object",
        "required": [
          "crawler",
          "results"
        ],
        "title": "CrawlResponse"
      },
      "CrawlUrlResult": {
        "properties": {
          "url": {
            "type": "string",
            "title": "Url"
          },
          "content": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Content",
            "description": "Markdown extracted from HTML responses; null when unprocessed"
          },
          "contentType": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Contenttype",
            "description": "Response Content-Type (media type only, parameters stripped)"
          },
          "error": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/PerUrlError"
              },
              {
                "type": "null"
              }
            ]
          },
          "raw": {
            "anyOf": [
              {},
              {
                "type": "null"
              }
            ],
            "title": "Raw",
            "description": "Unmodified response body text, or null when no body was received"
          }
        },
        "type": "object",
        "required": [
          "url"
        ],
        "title": "CrawlUrlResult"
      },
      "ExposableEI": {
        "properties": {
          "expose": {
            "type": "boolean",
            "title": "Expose",
            "description": "When true, this parameter is included on the LLM call JSON Schema."
          },
          "value": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "e",
                  "i"
                ]
              },
              {
                "type": "null"
              }
            ],
            "title": "Value",
            "description": "Admin default merged into each search when not ``None``."
          }
        },
        "type": "object",
        "required": [
          "expose",
          "value"
        ],
        "title": "ExposableEI"
      },
      "ExposableStr": {
        "properties": {
          "expose": {
            "type": "boolean",
            "title": "Expose",
            "description": "When true, this parameter is included on the LLM call JSON Schema."
          },
          "value": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Value",
            "description": "Admin default merged into each search when not ``None``."
          }
        },
        "type": "object",
        "required": [
          "expose",
          "value"
        ],
        "title": "ExposableStr"
      },
      "GoogleConfig": {
        "properties": {
          "engine": {
            "type": "string",
            "const": "google",
            "title": "Search engine",
            "description": "Provider discriminator; must be `google` for this config.",
            "default": "google"
          },
          "fetchSize": {
            "type": "integer",
            "maximum": 100.0,
            "minimum": 1.0,
            "title": "Fetchsize",
            "description": "Default result count merged into each search request",
            "default": 10
          },
          "timeout": {
            "type": "integer",
            "maximum": 600.0,
            "minimum": 1.0,
            "title": "Timeout",
            "description": "Request timeout in seconds",
            "default": 30
          },
          "searchEngineId": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Search engine ID (cx)",
            "description": "Google Programmable Search Engine ID (`cx`). Defaults from `GOOGLE_SEARCH_ENGINE_ID` when deployed. Not sent as a query parameter (resolved at runtime)."
          },
          "safe": {
            "type": "string",
            "enum": [
              "active",
              "off"
            ],
            "title": "Safe search",
            "description": "SafeSearch level for every search: `active` (default) or `off`. Applied on all requests unless the call body overrides it.",
            "default": "active"
          },
          "gl": {
            "$ref": "#/components/schemas/ExposableStr",
            "title": "Geolocation (gl)",
            "description": "Two-letter ISO 3166-1 alpha-2 country code (Google `gl`). Set `value` for a fixed default; set `expose` so the LLM may override per query."
          },
          "hl": {
            "$ref": "#/components/schemas/ExposableStr",
            "title": "Interface language (hl)",
            "description": "Language for snippets/UI (Google `hl`). `value` + `expose` behave like `gl`."
          },
          "lr": {
            "$ref": "#/components/schemas/ExposableStr",
            "title": "Language restrict (lr)",
            "description": "Document language restrict (Google `lr`), e.g. `lang_en`. `value` + `expose` behave like `gl`."
          },
          "dateRestrict": {
            "$ref": "#/components/schemas/ExposableStr",
            "title": "Date restrict",
            "description": "Google `dateRestrict` recency filter (`d7`, `m1`, \u2026). `value` + `expose` behave like `gl`."
          },
          "exactTerms": {
            "$ref": "#/components/schemas/ExposableStr",
            "title": "Exact terms",
            "description": "Phrase every hit must contain (Google `exactTerms`). `value` + `expose` behave like `gl`."
          },
          "excludeTerms": {
            "$ref": "#/components/schemas/ExposableStr",
            "title": "Exclude terms",
            "description": "Phrase that must not appear (Google `excludeTerms`). `value` + `expose` behave like `gl`."
          },
          "fileType": {
            "$ref": "#/components/schemas/ExposableStr",
            "title": "File type",
            "description": "File extension filter (Google `fileType`), e.g. `pdf`. `value` + `expose` behave like `gl`."
          },
          "siteSearch": {
            "$ref": "#/components/schemas/ExposableStr",
            "title": "Site search",
            "description": "Site or domain (Google `siteSearch`). Pair with `siteSearchFilter`. `value` + `expose` behave like `gl`."
          },
          "siteSearchFilter": {
            "$ref": "#/components/schemas/ExposableEI",
            "title": "Site search filter",
            "description": "With `siteSearch`: `i` = include only that site, `e` = exclude. `value` + `expose` behave like `gl`."
          },
          "sort": {
            "$ref": "#/components/schemas/ExposableStr",
            "title": "Sort",
            "description": "Sort expression (Google `sort`), e.g. `date`. `value` + `expose` behave like `gl`."
          }
        },
        "type": "object",
        "title": "GoogleConfig",
        "description": "Single source of truth for Google deployment + derived request/LLM surfaces."
      },
      "GoogleConfigRequest": {
        "properties": {
          "query": {
            "type": "string",
            "minLength": 1,
            "title": "Query",
            "description": "Search query string"
          },
          "engine": {
            "type": "string",
            "const": "google",
            "title": "Search engine",
            "description": "Provider discriminator; must be `google` for this config.",
            "default": "google"
          },
          "fetchSize": {
            "type": "integer",
            "title": "Fetchsize",
            "description": "Default result count merged into each search request",
            "default": 10
          },
          "timeout": {
            "type": "integer",
            "title": "Timeout",
            "description": "Request timeout in seconds",
            "default": 30
          },
          "searchEngineId": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Search engine ID (cx)",
            "description": "Google Programmable Search Engine ID (`cx`). Defaults from `GOOGLE_SEARCH_ENGINE_ID` when deployed. Not sent as a query parameter (resolved at runtime).",
            "default": "00c5f6e9ac4644f42"
          },
          "safe": {
            "type": "string",
            "enum": [
              "active",
              "off"
            ],
            "title": "Safe search",
            "description": "SafeSearch level for every search: `active` (default) or `off`. Applied on all requests unless the call body overrides it.",
            "default": "active"
          },
          "gl": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
