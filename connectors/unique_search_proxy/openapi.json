              }
            }
          }
        }
      }
    },
    "/v1/configuration/search-engines/{engine_id}/call-schema": {
      "post": {
        "tags": [
          "configuration"
        ],
        "summary": "JSON Schema for POST /v1/search from deployment config",
        "operationId": "search_engine_call_schema_v1_configuration_search_engines__engine_id__call_schema_post",
        "parameters": [
          {
            "name": "engine_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Engine Id"
            }
          },
          {
            "name": "strict",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "description": "When true (default), the call schema marks every exposed field as required with no defaults (for strict LLM JSON generation). When false, optional provider knobs keep nullable types and defaults.",
              "default": true,
              "title": "Strict"
            },
            "description": "When true (default), the call schema marks every exposed field as required with no defaults (for strict LLM JSON generation). When false, optional provider knobs keep nullable types and defaults."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GoogleConfig"
              },
              "examples": {
                "default_projection": {
                  "summary": "Call schema (query + fetchSize only)",
                  "description": "Default LLM projection when optional params are not exposed.",
                  "value": {
                    "engine": "google",
                    "fetchSize": 10,
                    "safe": "active"
                  }
                },
                "with_exposed_params": {
                  "summary": "Call schema (+ gl)",
                  "description": "`gl.expose=true` adds `gl` to the LLM call schema; `dateRestrict` stays merge-only.",
                  "value": {
                    "engine": "google",
                    "fetchSize": 10,
                    "safe": "active",
                    "gl": {
                      "expose": true,
                      "value": "ch"
                    },
                    "dateRestrict": {
                      "expose": false,
                      "value": "d7"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchCallSchemaResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/v1/configuration/crawlers/json-schema": {
      "get": {
        "tags": [
