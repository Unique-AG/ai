{
  "realm": "producer",
  "displayName": "Producer Domain",
  "enabled": true,
  "ssoSessionMaxLifespan": 36000,
  "accessTokenLifespan": 3600,
  "accessTokenLifespanForImplicitFlow": 900,

  "clients": [
    {
      "clientId": "resource-producer",
      "name": "Resource Producer MCP Server",
      "description": "Bearer-only resource server; token exchange target.",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "frontchannelLogout": true,
      "protocol": "openid-connect",
      "rootUrl": "http://producer:8001/mcp",
      "baseUrl": "/",
      "webOrigins": ["http://producer:8001"],
      "protocolMappers": [
        {
          "name": "producer-mcp-url-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "http://producer:8001/mcp",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "lightweight.claim": "false"
          }
        }
      ]
    },

    {
      "clientId": "resource-consumer-service",
      "name": "Resource Consumer Service",
      "description": "The consumer MCP server acting as a trusted deputy when archiving notes.",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect"
    },

    {
      "clientId": "alice-desktop-app",
      "name": "Alice Desktop App",
      "description": "Public client — used by the demo script to initiate exchanges directly.",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect"
    }
  ],

  "identityProviders": [
    {
      "alias": "dex",
      "displayName": "Dex (Consumer IdP)",
      "internalId": "dex-idp",
      "providerId": "oidc",
      "enabled": true,
      "updateProfileFirstLoginMode": "on",
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "authenticateByDefault": false,
      "linkOnly": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "discoveryEndpoint": "http://dex:5556/.well-known/openid-configuration",
        "useDiscoveryEndpoint": "true",
        "clientId": "keycloak-federation",
        "clientSecret": "keycloak-federation-secret",
        "clientAuthMethod": "client_secret_post",
        "defaultScope": "openid profile email",
        "syncMode": "IMPORT",
        "validateSignature": "true",
        "useJwksUrl": "true",
        "jwksUrl": "http://dex:5556/keys",
        "userInfoUrl": "http://dex:5556/userinfo",
        "disableUserInfo": "false",
        "pkceEnabled": "false"
      }
    }
  ],

  "identityProviderMappers": [
    {
      "name": "dex-username-to-keycloak-username",
      "identityProviderAlias": "dex",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "claim": "preferred_username",
        "user.attribute": "username"
      }
    },
    {
      "name": "dex-email-to-keycloak-email",
      "identityProviderAlias": "dex",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "claim": "email",
        "user.attribute": "email"
      }
    }
  ]
}
