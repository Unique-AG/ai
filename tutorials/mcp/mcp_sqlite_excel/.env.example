# Excel / SQLite (AppSettings)
# EXCEL_PATH=./data/sample_portfolio.xlsx
# SQLITE_PATH=./data/portfolio.db
# Force header on a specific 1-based Excel row (otherwise auto-detect):
# EXCEL_HEADER_ROW=4
# EXCEL_MIN_HEADER_CELLS=3

# Local demos only — skips Zitadel OIDC (do not use in production)
# AUTH_DISABLED=true

# Prefer the dedicated env files (same as mcp_search):
#   cp zitadel.env.example zitadel.env
#   cp unique_mcp.env.example unique_mcp.env
#
# Or set the same variables here:
# ZITADEL_BASE_URL=https://id.unique.app
# ZITADEL_CLIENT_ID=
# ZITADEL_CLIENT_SECRET=
# UNIQUE_MCP_PUBLIC_BASE_URL=https://your-public-url.example.com
# UNIQUE_MCP_LOCAL_BASE_URL=http://127.0.0.1:8004

# Azure deploy (./deploy.sh) — reuses mcp_search resource group by default
# AZURE_SUBSCRIPTION_ID=
# RG=rg-lab-demo-001-unique-search-mcp
