---
type IconName =
  | "alert-circle"
  | "bot"
  | "check-circle"
  | "chevron-down"
  | "chevron-left"
  | "chevron-right"
  | "chevron-up"
  | "circle-arrow-up"
  | "mail"
  | "minus"
  | "siren"
  | "sparkles"
  | "user";

export interface Props {
  name: IconName;
  class?: string;
  size?: number;
}

const { name, class: className, size = 16 } = Astro.props;

const paths: Record<IconName, string> = {
  "alert-circle": '<circle cx="12" cy="12" r="10"></circle><line x1="12" x2="12" y1="8" y2="12"></line><line x1="12" x2="12.01" y1="16" y2="16"></line>',
  bot: '<path d="M12 8V4H8"></path><rect width="16" height="12" x="4" y="8" rx="2"></rect><path d="M2 14h2"></path><path d="M20 14h2"></path><path d="M15 13v2"></path><path d="M9 13v2"></path>',
  "check-circle": '<path d="M9 12l2 2 4-4"></path><circle cx="12" cy="12" r="10"></circle>',
  "chevron-down": '<path d="m6 9 6 6 6-6"></path>',
  "chevron-left": '<path d="m15 18-6-6 6-6"></path>',
  "chevron-right": '<path d="m9 18 6-6-6-6"></path>',
  "chevron-up": '<path d="m18 15-6-6-6 6"></path>',
  "circle-arrow-up": '<circle cx="12" cy="12" r="10"></circle><path d="m16 12-4-4-4 4"></path><path d="M12 16V8"></path>',
  mail: '<rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>',
  minus: '<path d="M5 12h14"></path>',
  siren: '<path d="M7 18v-6a5 5 0 0 1 10 0v6"></path><path d="M5 21h14"></path><path d="M21 12h1"></path><path d="M18.5 4.5 18 5"></path><path d="M2 12h1"></path><path d="M6 5l-.5-.5"></path>',
  sparkles: '<path d="M9.9 4.24 8.73 7.36 5.6 8.53l3.13 1.17 1.17 3.12 1.17-3.12 3.12-1.17-3.12-1.17Z"></path><path d="M19 12.5 18.1 15l-2.6.9 2.6.9.9 2.7.9-2.7 2.6-.9-2.6-.9Z"></path><path d="M4.5 13.5 4 15l-1.5.5L4 16l.5 1.5L5 16l1.5-.5L5 15Z"></path>',
  user: '<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle>',
};
---

<svg
  class:list={["lucide-icon", className]}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={paths[name]}
/>
