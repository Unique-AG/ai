# Public URL clients use to reach the server (OAuth callbacks / metadata).
# Local + ngrok: https://<subdomain>.ngrok-free.app
# Azure: https://sqlite-excel-mcp.azurewebsites.net
# The public hostname is also allowlisted for FastMCP HostOriginGuard (avoids HTTP 421).
UNIQUE_MCP_PUBLIC_BASE_URL=https://your-public-url.example.com

# Local bind address for the server process.
UNIQUE_MCP_LOCAL_BASE_URL=http://127.0.0.1:8004
