# Public URL where the MCP server is reachable by clients.
# For local dev with ngrok: https://your-subdomain.ngrok-free.app
# For Azure deployment: https://your-domain.com
# Leave unset to default to LOCAL_BASE_URL.
UNIQUE_MCP_PUBLIC_BASE_URL=https://your-public-url.example.com

# Local bind address for the server process.
UNIQUE_MCP_LOCAL_BASE_URL=http://127.0.0.1:8003

# Unique web app origin for clickable knowledge-upload links in search results
# (e.g. https://next.qa.unique.app). Optional; falls back to unique://content/{id}.
UNIQUE_MCP_FRONTEND_BASE_URL=
