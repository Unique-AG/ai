# Copy to deploy.env (gitignored) and fill in your target environment.
# Every value can also be provided as an environment variable instead.

# Azure subscription id
SUBSCRIPTION=
# Existing resource group to deploy into
RG=
# Web App name (also the image repository name; globally unique)
APP=
# Azure Container Registry name (created on first run if missing)
ACR=
# Optional: App Service plan name (default: ${APP}-plan)
# PLAN=
# Optional: Unique frontend origin for document deep links
# UNIQUE_MCP_FRONTEND_BASE_URL=https://next.qa.unique.app
